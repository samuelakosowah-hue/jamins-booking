# FALLBACK for shared hosting where you cannot set the document root to public/.
#
# The RECOMMENDED setup is to point your domain at the public/ folder, in which case
# this file is never read (it sits above the document root) and public/.htaccess does
# the work. Only when the domain points at this project root does this file apply: it
# hides the application internals and forwards every request into public/.

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block direct access to everything that isn't meant to be web-served.
    RewriteRule ^(config\.php|config\.local\.php|config\.local\.example\.php) - [F,L]
    RewriteRule ^(DEPLOY|README)\.md - [F,L]
    RewriteRule ^(src|views|data)/ - [F,L]

    # Serve real files that live inside public/ (the stylesheet, favicon).
    RewriteCond %{DOCUMENT_ROOT}/public%{REQUEST_URI} -f
    RewriteRule ^(.*)$ public/$1 [L]

    # Route everything else through the front controller.
    RewriteRule ^ public/index.php [L]
</IfModule>

# Belt-and-braces: refuse dotfiles here too.
<FilesMatch "^\.">
    Require all denied
</FilesMatch>
