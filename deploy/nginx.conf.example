# Nginx server block for Jamin's Nutrition Consult booking site.
# Nginx ignores .htaccess, so this replaces all of them. Adjust the paths,
# server_name, and the PHP-FPM socket to match your server, then reload nginx.

server {
    listen 80;
    server_name booking.example.com;

    # Send all plain HTTP to HTTPS.
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name booking.example.com;

    ssl_certificate     /etc/letsencrypt/live/booking.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/booking.example.com/privkey.pem;

    # IMPORTANT: the web root is the public/ folder, never the project root.
    root /var/www/event-booking/public;
    index index.php;

    # Static files served directly; everything else hits the front controller.
    location / {
        try_files $uri $uri/ /index.php$is_args$args;
    }

    location ~ \.php$ {
        include fastcgi_params;
        fastcgi_pass unix:/run/php/php8.2-fpm.sock;   # match your PHP-FPM socket
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        # Lets PHP detect HTTPS behind the proxy.
        fastcgi_param HTTPS on;
    }

    # The project's data/, src/, views/ and config files sit OUTSIDE this root
    # (one level up), so they are already unreachable. This is defence in depth.
    location ~ /\. { deny all; }

    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    client_max_body_size 2m;
}
